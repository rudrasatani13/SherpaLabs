{
  "name": "@sherpa-labs/core-rules",
  "version": "0.0.0",
  "private": true,
  "description": "Parsing and audit engine for Markdown-style agent rule files (CLAUDE.md, .cursor/rules/*, AGENTS.md, .windsurfrules).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sherpa-labs-io/SherpaLabs.git",
    "directory": "packages/core-rules"
  },
  "homepage": "https://github.com/sherpa-labs-io/SherpaLabs/tree/main/packages/core-rules#readme",
  "bugs": "https://github.com/sherpa-labs-io/SherpaLabs/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./parser": {
      "types": "./dist/parser/index.d.ts",
      "default": "./dist/parser/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "test": "vitest run"
  },
  "dependencies": {
    "@sherpa-labs/core-utils": "workspace:*",
    "@sherpa-labs/shared-types": "workspace:*",
    "fast-glob": "^3.3.2",
    "marked": "^15.0.4",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@sherpa-labs/shared-config": "workspace:*",
    "@types/node": "^25.9.1",
    "vitest": "^4.1.7"
  }
}
