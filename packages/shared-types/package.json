{
  "name": "@sherpa-labs/shared-types",
  "version": "0.0.0",
  "private": true,
  "description": "Cross-package TypeScript types shared across Sherpa Labs CLIs, the API, and the dashboard.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sherpa-labs-io/SherpaLabs.git",
    "directory": "packages/shared-types"
  },
  "homepage": "https://github.com/sherpa-labs-io/SherpaLabs/tree/main/packages/shared-types#readme",
  "bugs": "https://github.com/sherpa-labs-io/SherpaLabs/issues",
  "type": "module",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts"
    },
    "./api": {
      "types": "./dist/api.d.ts"
    },
    "./audit": {
      "types": "./dist/audit.d.ts"
    },
    "./common": {
      "types": "./dist/common.d.ts"
    },
    "./domain": {
      "types": "./dist/domain.d.ts"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts"
    },
    "./rule-files": {
      "types": "./dist/rule-files.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean"
  },
  "devDependencies": {
    "@sherpa-labs/shared-config": "workspace:*"
  }
}
