{
  "name": "@sherpa-labs/aimcp-lint",
  "version": "0.0.1",
  "description": "Lint your MCP server for protocol compliance, schema violations, security issues, and performance best practices.",
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lint",
    "linter",
    "cli",
    "mcp-server",
    "sherpa-labs"
  ],
  "author": "Sherpa Labs <hello@sherpalabs.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudrasatani13/SherpaLabs.git",
    "directory": "packages/cli-aimcp"
  },
  "homepage": "https://github.com/rudrasatani13/SherpaLabs/tree/main/packages/cli-aimcp#readme",
  "bugs": "https://github.com/rudrasatani13/SherpaLabs/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "aimcp-lint": "./dist/index.js"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && tsc --build --force",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "pnpm build && vitest run",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@sherpa-labs/core-mcp": "workspace:*",
    "@sherpa-labs/shared-config": "workspace:*",
    "@types/node": "^25.9.1",
    "tsup": "^8.0.0",
    "vitest": "^4.1.7"
  }
}
