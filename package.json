{
  "name": "sherpa-labs",
  "version": "0.0.0",
  "private": true,
  "description": "Sherpa Labs — better rules, smarter agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rudrasatani13/SherpaLabs.git"
  },
  "homepage": "https://github.com/rudrasatani13/SherpaLabs#readme",
  "bugs": "https://github.com/rudrasatani13/SherpaLabs/issues",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22.22.3",
    "pnpm": ">=11.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:clean": "tsc --build --clean",
    "typecheck": "tsc --build --dry",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r --if-present test",
    "test:pack:aimcp-lint": "node tools/phase25/aimcp-lint-pack-smoke.mjs",
    "validate:action-template": "node tools/phase25/validate-aimcp-lint-action.mjs",
    "validate:phase25": "pnpm test:pack:aimcp-lint && pnpm validate:action-template",
    "assets": "pnpm -F @sherpa-labs/asset-build build",
    "changeset": "changeset",
    "changeset:status": "changeset status --verbose",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.4",
    "@sherpa-labs/shared-config": "workspace:*",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "typescript": "5.6.3",
    "typescript-eslint": "^8.59.4",
    "yaml": "^2.9.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
